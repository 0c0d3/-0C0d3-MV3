{
  "manifest_version": 3,
  "name": "0c0d3",
  "version": "1.2.4",
  "description": "made with zero code",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "0c0d3",
    "default_icon": {
      "48": "icons/icon.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["cosmetics.js", "scriptlets.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icons/icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ublockfull@custom",
      "strict_min_version": "109.0"
    }
  }
}