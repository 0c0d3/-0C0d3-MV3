{
  "manifest_version": 3,
  "name": "0c0d3",
  "version": "3.0.1",
  "description": "0c0d3 Ad-Blocker",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/observer.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "0c0d3 Ad-Blocker",
    "default_icon": {
      "48": "icons/icon.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*.jsonx", "assets/*.json", "assets/cosmetics/*.json", "assets/cosmetic-index.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "icons/icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{bb6f4d85-3cea-4bb4-8599-be8362e09673}",
      "strict_min_version": "109.0"
    }
  }
}
